  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@garuhq/node": "0.2.0",
    "@modelcontextprotocol/sdk": "1.12.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "22.15.2",
    "tsup": "8.4.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
